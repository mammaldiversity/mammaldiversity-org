---
import cntl from "cntl";

interface Props {
  // Additional info to help reader understand the taxon rank
  label?: string;
  taxonName: string;
  url?: string; // optional, if provided, taxon name will be a link
  italic?: boolean; // optional, if true, taxon name will be italicized
}

const { label, taxonName, url, italic } = Astro.props as Props;

const containerClasses = cntl`
  my-1
  text-sm
  mr-2

`;

const labelClasses = cntl`
  text-xs
  text-spectra-800
  dark:text-spectra-300
`;

const textClasses = cntl`
  tracking-wide
  ${italic ? "italic" : ""}
`;

const urlClasses = cntl`
  underline
  hover:text-spectra-700
  dark:hover:text-spectra-200
  ${italic ? "italic" : ""}
`;
---

<div class={containerClasses}>
  {label && <p class={labelClasses}>{label}</p>}
  {
    url ? (
      <>
        <a class={urlClasses} href={url}>
          {taxonName}
        </a>
      </>
    ) : (
      <p class={textClasses}>{taxonName}</p>
    )
  }
</div>
