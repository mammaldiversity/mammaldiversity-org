---
import TreeTips from "./TreeTips.astro";
import type { PhyloNode } from "../../libs/phylogeny";
import {
  generateSpeciesLink,
  generateFamilyLink,
  generateOrderLink,
} from "../../libs/permalink";

interface Props {
  nodes: PhyloNode[];
}

const { nodes } = Astro.props;

function getUrl(node: PhyloNode) {
  if (node.rank === "order") return generateOrderLink(node.name.toLowerCase());
  if (node.rank === "family")
    return generateFamilyLink(node.name.toLowerCase());
  if (node.rank === "species" && node.mddId)
    return generateSpeciesLink(node.mddId);
  return undefined;
}

function getLabel(node: PhyloNode) {
  if (node.rank === "species") return "Species";
  return node.rank.charAt(0).toUpperCase() + node.rank.slice(1);
}
---

<div class="ml-2">
  {
    nodes.map((node, i) => (
      <TreeTips
        label={getLabel(node)}
        taxonName={node.name}
        idx={i}
        length={nodes.length}
        childCount={node.children.length > 0 ? node.children.length : undefined}
        expanded={node.rank === "family" || node.rank === "order"}
        url={getUrl(node)}
        italic={
          node.rank === "species" ||
          node.rank === "genus" ||
          node.rank === "subgenus"
        }
      >
        {node.children.length > 0 ? <Astro.self nodes={node.children} /> : null}
      </TreeTips>
    ))
  }
</div>
