---
import { Image } from "astro:assets";
import iphoneBradypus from "../assets/images/screenshots/iphoneBradypus.webp";
import iphoneHome from "../assets/images/screenshots/iphoneHome.webp";
import macVombatus from "../assets/images/screenshots/macVombatus.webp";
import GooglePlayBadge from "../assets/app-stores/GooglePlayBadge.svg";

import cntl from "cntl";
import Link from "./Link.astro";

const sectionTitleClass = cntl`
  font-serif
  text-3xl
  lg:text-4xl
  font-semibold
  text-center
  mb-10
  mt-12
`;

const bentoCellClasses = cntl`
  bg-gradient-to-br
  dark:from-spectra-900
  dark:to-spectra-800/30
  from-spectra-50
  to-spectra-100/50
  rounded-[2rem]
  p-6
  md:p-8
  border
  dark:border-spectra-800
  border-spectra-200/60
  overflow-hidden
  relative
  shadow-sm
  hover:shadow-md
  transition-all
  duration-300
  group
`;
---

<div>
  <h2 class={sectionTitleClass}>Install the MDD App</h2>

  <div
    class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 max-w-6xl mx-auto px-4 mb-16"
  >
    <div
      class={`${bentoCellClasses} md:col-span-2 md:row-span-2 flex flex-col sm:flex-row items-center gap-8 sm:gap-4`}
    >
      <div class="flex-1 text-left z-10 w-full sm:pr-4 pt-4 sm:pt-0">
        <div
          class="inline-flex items-center space-x-2 bg-spectra-200/50 dark:bg-spectra-800/50 rounded-full px-3 py-1 mb-6"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"
            ></span>
          </span>
          <span
            class="text-xs font-medium text-spectra-800 dark:text-spectra-200"
            >Available Now</span
          >
        </div>
        <h3
          class="text-3xl md:text-4xl font-serif font-semibold mb-4 leading-tight"
        >
          The MDD App
        </h3>
        <p
          class="text-spectra-700 dark:text-spectra-300 mb-8 leading-relaxed text-base md:text-lg"
        >
          Access the entire Mammal Diversity Database on the go, anywhere.
        </p>
        <div class="flex flex-col gap-4">
          <a
            href="https://play.google.com/store/apps/details?id=com.hhandika.mdd"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block transition-transform hover:scale-105 origin-left"
          >
            <Image
              height="50"
              src={GooglePlayBadge}
              alt="Get it on Google Play"
            />
          </a>
          <p class="text-sm dark:text-spectra-400 text-spectra-600">
            Follow <Link
              url="https://github.com/mammaldiversity/mdd_app/releases/latest"
              label="installation guidelines"
              openInNewTab={true}
            /> to install on other platforms.
          </p>
        </div>
      </div>
      <div
        class="flex-1 w-full flex justify-center sm:justify-end relative sm:-mr-8 md:-mr-12 lg:-mr-16 mt-8 sm:mt-0"
      >
        <Image
          src={iphoneHome}
          alt="MDD App Home Screen"
          class="w-56 sm:w-64 md:w-72 lg:w-80 drop-shadow-[0_20px_40px_rgba(0,0,0,0.25)] transform group-hover:-translate-y-2 transition-transform duration-500"
        />
      </div>
    </div>
    <!-- Advanced Search Cell -->
    <div class={`${bentoCellClasses} flex flex-col justify-between`}>
      <div class="z-10">
        <div
          class="w-12 h-12 rounded-2xl bg-white/80 dark:bg-spectra-800 flex items-center justify-center mb-5 shadow-sm border border-spectra-100 dark:border-spectra-700 backdrop-blur-sm"
        >
          <svg
            class="w-6 h-6 text-blue-600 dark:text-blue-400"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg
          >
        </div>
        <h3 class="text-xl font-semibold mb-2">Advanced Search</h3>
        <p class="text-sm text-spectra-600 dark:text-spectra-400 mb-8">
          Quickly search and filter thousands of mammal species, their
          associated names, and synonyms with our highly optimized local search
          engine.
        </p>
      </div>
      <div
        class="mt-auto -mb-16 -mx-4 flex justify-center transform group-hover:-translate-y-2 group-hover:scale-105 transition-all duration-500"
      >
        <Image
          src={iphoneBradypus}
          alt="Search Screen"
          class="w-36 sm:w-44 drop-shadow-[0_15px_30px_rgba(0,0,0,0.2)] rounded-t-[2rem] border-t-[6px] border-l-[6px] border-r-[6px] border-gray-800 dark:border-gray-900"
        />
      </div>
    </div>

    <div class={`${bentoCellClasses} flex flex-col justify-center`}>
      <div
        class="w-12 h-12 rounded-2xl bg-white/80 dark:bg-spectra-800 flex items-center justify-center mb-5 shadow-sm border border-spectra-100 dark:border-spectra-700 backdrop-blur-sm"
      >
        <svg
          class="w-6 h-6 text-green-600 dark:text-green-400"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"
          ></path></svg
        >
      </div>
      <h3 class="text-xl font-semibold mb-2">Works Offline</h3>
      <p class="text-sm text-spectra-600 dark:text-spectra-400">
        The entire dataset comes fully bundled, including the MIL images. No
        internet required for your remote fieldwork.
      </p>
    </div>

    <div
      class={`${bentoCellClasses} md:col-span-2 flex flex-col sm:flex-row items-center justify-between`}
    >
      <div class="flex-1 mb-8 sm:mb-0 sm:pr-8 z-10 w-full">
        <div
          class="w-12 h-12 rounded-2xl bg-white/80 dark:bg-spectra-800 flex items-center justify-center mb-5 shadow-sm border border-spectra-100 dark:border-spectra-700 backdrop-blur-sm"
        >
          <svg
            class="w-6 h-6 text-purple-600 dark:text-purple-400"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path></svg
          >
        </div>
        <h3 class="text-xl font-semibold mb-2">Cross-Platform Native</h3>
        <p class="text-sm text-spectra-600 dark:text-spectra-400 mb-6">
          Enjoy a native, fast experience on iOS, Android, macOS, Windows, and
          Linux. Built completely from the ground up.
        </p>
        <ul class="flex flex-wrap gap-2">
          {
            ["iOS", "Android", "macOS", "Windows", "Linux"].map((platform) => (
              <li class="px-3 py-1.5 text-xs font-semibold bg-white/60 dark:bg-spectra-800/80 rounded-xl text-spectra-700 dark:text-spectra-300 border border-spectra-200 dark:border-spectra-700 shadow-sm">
                {platform}
              </li>
            ))
          }
        </ul>
      </div>
      <div
        class="flex-1 w-full flex justify-center sm:justify-end -mb-12 sm:-mb-16 -mr-4 sm:-mr-8 lg:-mr-12 relative transform group-hover:-translate-x-2 group-hover:-translate-y-2 group-hover:scale-105 transition-all duration-500 origin-bottom-right"
      >
        <Image
          src={macVombatus}
          alt="Mac App Screen"
          class="w-64 sm:w-80 md:w-[22rem] lg:w-[26rem] drop-shadow-[0_15px_30px_rgba(0,0,0,0.3)] rounded-tl-xl"
        />
      </div>
    </div>

    <!-- Custom Exports Cell -->
    <div
      class={`${bentoCellClasses} md:col-span-1 flex flex-col justify-center`}
    >
      <div
        class="w-12 h-12 rounded-2xl bg-white/80 dark:bg-spectra-800 flex items-center justify-center mb-5 shadow-sm border border-spectra-100 dark:border-spectra-700 backdrop-blur-sm"
      >
        <svg
          class="w-6 h-6 text-orange-600 dark:text-orange-400"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path></svg
        >
      </div>
      <h3 class="text-xl font-semibold mb-2">Custom Exports</h3>
      <p class="text-sm text-spectra-600 dark:text-spectra-400">
        Easily generate customized reports, citations, and species lists
        tailored for your workflow.
      </p>
    </div>
  </div>
</div>
