---
import cntl from "cntl";
import Link from "../Link.astro";

const sectionTitleClass = cntl`
  font-serif
  text-3xl
  lg:text-4xl
  font-semibold
  text-center
  mt-16
  mb-10
  text-spectra-900
  dark:text-spectra-50
`;

const whatsNewCard = cntl`
  bg-white/80
  dark:bg-spectra-800/80
  backdrop-blur-sm
  rounded-2xl
  p-6
  shadow-sm
  border
  border-spectra-200/60
  dark:border-spectra-700/60
  hover:shadow-md
  transition-all
  duration-300
`;
---

<div>
  <h2 class={sectionTitleClass}>What's New in the MDD2</h2>
  <div
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto"
  >
    <div class={whatsNewCard}>
      <div
        class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center mb-4 text-blue-600 dark:text-blue-400"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          ></path></svg
        >
      </div>
      <p class="text-sm text-spectra-800 dark:text-spectra-200">
        Codings of US state, country, continent, and biogeographic realm
        geographic categories for each species. <Link
          url="/country/US"
          label="See U.S. state species list"
        />.
      </p>
    </div>
    <div class={whatsNewCard}>
      <div
        class="w-10 h-10 rounded-full bg-purple-100 dark:bg-purple-900/50 flex items-center justify-center mb-4 text-purple-600 dark:text-purple-400"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
          ></path></svg
        >
      </div>
      <p class="text-sm text-spectra-800 dark:text-spectra-200">
        A comprehensive nomenclatural dataset for 50,000+ synonymous
        species-rank names, curated with type locality and specimen information.
      </p>
    </div>
    <div class={whatsNewCard}>
      <div
        class="w-10 h-10 rounded-full bg-green-100 dark:bg-green-900/50 flex items-center justify-center mb-4 text-green-600 dark:text-green-400"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
          ></path></svg
        >
      </div>
      <p class="text-sm text-spectra-800 dark:text-spectra-200">
        Integration between the MDD, the databases Hesperomys, Batnames, and the
        Mammal Images Library (MIL) for greater data accuracy and completeness.
      </p>
    </div>
    <div class={whatsNewCard}>
      <div
        class="w-10 h-10 rounded-full bg-orange-100 dark:bg-orange-900/50 flex items-center justify-center mb-4 text-orange-600 dark:text-orange-400"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path></svg
        >
      </div>
      <p class="text-sm text-spectra-800 dark:text-spectra-200">
        A rewritten and redesigned of the MDD website with a new search feature
        and better scalability for supporting future features. The original
        version is available at <Link
          url="http://classic.mammaldiversity.org"
          label="classic.mammaldiversity.org"
        />.
      </p>
    </div>
    <div class={whatsNewCard}>
      <div
        class="w-10 h-10 rounded-full bg-cyan-100 dark:bg-cyan-900/50 flex items-center justify-center mb-4 text-cyan-600 dark:text-cyan-400"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"
          ></path></svg
        >
      </div>
      <p class="text-sm text-spectra-800 dark:text-spectra-200">
        Discover more ways to explore the database and view in-depth data
        statistics, including taxonomic tables and interactive geographic maps. <Link
          url="/explore"
          label="Visit the explore page"
        />.
      </p>
    </div>
    <div class={whatsNewCard}>
      <div
        class="w-10 h-10 rounded-full bg-red-100 dark:bg-red-900/50 flex items-center justify-center mb-4 text-red-600 dark:text-red-400"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
          ></path></svg
        >
      </div>
      <p class="text-sm text-spectra-800 dark:text-spectra-200">
        A new cross-platform app offering offline access to MDD, advanced search
        capabilities, custom exports, and more. Check out the "Install MDD App"
        section below.
      </p>
    </div>
  </div>
</div>
