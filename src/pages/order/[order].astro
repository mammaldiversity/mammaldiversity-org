---
import { getOrder, getSpeciesData } from "../../../db/mdd";
import PageDivider from "../../components/PageDivider.astro";
import Title from "../../components/Title.astro";
import MainPage from "../../layouts/MainPage.astro";
import Page from "../../layouts/Page.astro";
import cntl from "cntl";
import { buildPhylogeneticTree } from "../../libs/phylogeny";
import RecursiveTreeTips from "../../components/phylo/RecursiveTreeTips.astro";
import PhyloContainer from "../../layouts/PhyloContainer.astro";
import { getMilImagesByMddIds } from "../../libs/mil";
import { Image } from "astro:assets";
import { MilAttribution } from "../../components/mil/Attribution";
import { generateSpeciesLink } from "../../libs/permalink";

const headerClasses = cntl`
  text-center
  text-xl 
  md:text-2xl 
  text-spectra-800 
  dark:text-spectra-200 
  mb-2
`;

export const getStaticPaths = async () => {
  const data = getOrder();
  return data.map((taxonOrder: string) => ({
    params: { order: taxonOrder.toLowerCase() },
    props: { taxonOrder },
  }));
};

const { taxonOrder } = Astro.props;

const tree = buildPhylogeneticTree({
  filterByRank: "order",
  filterByName: taxonOrder,
  maxDepth: 4,
});

const speciesData = getSpeciesData();
const mddIds = speciesData
  .filter(
    (s) => s.speciesData.taxonOrder.toLowerCase() === taxonOrder.toLowerCase(),
  )
  .map((s) => s.mddId);

const milImages = getMilImagesByMddIds(mddIds, 20);

const milLandscapes = milImages.filter(
  (img) => img.orientation === "landscape",
);
const milPortraits = milImages.filter((img) => img.orientation === "portrait");

const root = tree.root;
---

<Page title={`${taxonOrder} Order`} isIndexed={false}>
  <MainPage isIndexed={false}>
    <div class="mt-8 md:mt-16">
      <p class={headerClasses}>Order</p>
      <Title bottomPadding={8}>{taxonOrder}</Title>
    </div>
    <PageDivider />
    {
      milImages.length > 0 && (
        <div class="ml-4">
          {milImages.length > 0 && (
            <div class="flex flex-wrap gap-2 my-2">
              {milLandscapes.map((milImage) => (
                <div class="flex flex-col items-center">
                  <a
                    href={generateSpeciesLink(milImage.mddId)}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <Image
                      src={milImage.filePath}
                      alt={milImage.description}
                      title={milImage.description}
                      width={120}
                      height={120}
                      class="max-w-[120px]"
                      loading="lazy"
                      decoding="async"
                      fetchpriority="low"
                    />
                  </a>
                </div>
              ))}
            </div>
          )}
          {milPortraits.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {milPortraits.map((milImage) => (
                <div class="flex flex-col items-center">
                  <a
                    href={generateSpeciesLink(milImage.mddId)}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <Image
                      src={milImage.filePath}
                      alt={milImage.description}
                      title={milImage.description}
                      width={120}
                      height={120}
                      class="max-w-[120px]"
                      loading="lazy"
                      decoding="async"
                      fetchpriority="low"
                    />
                  </a>
                </div>
              ))}
            </div>
          )}
          <MilAttribution client:load />
        </div>
      )
    }
    <PhyloContainer>
      {
        root.children.map((child, i) => (
          <>
            <h2 class="mb-2 font-bold text-xl">{child.name}</h2>
            <RecursiveTreeTips nodes={child.children} />
          </>
        ))
      }
    </PhyloContainer>
  </MainPage>
</Page>
